DEPLOY_ENV=local
DEBUG=True
SECRET_KEY=dev-local-secret-key

ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8010,http://localhost:8010,http://127.0.0.1,http://localhost
USE_X_FORWARDED_HOST=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
SECURE_CONTENT_TYPE_NOSNIFF=False

SITE_URL=http://127.0.0.1:8010
WEB_BIND=127.0.0.1
WEB_PORT=8010

DB_ENGINE=mysql
DB_NAME=xuanor_local
DB_TEST_NAME=xuanor_local
DB_USER=xuanor
DB_PASSWORD=xuanor
DB_HOST=127.0.0.1
DB_PORT=3306
MYSQL_ROOT_PASSWORD=xuanor_root
MYSQL_HOST_PORT=3307

CACHE_BACKEND=filebased
CACHE_LOCATION=/tmp/xuanor-cache
CACHE_KEY_PREFIX=xuanor-local
CACHE_TABLE=django_cache

DEFAULT_CURRENCY=USD
DEFAULT_SHIPPING_AMOUNT=15.00

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
EASYPOST_API_KEY=

OPENCLAW_ENABLED=False
OPENCLAW_COMMAND=openclaw
OPENCLAW_AGENT_ID=
OPENCLAW_TIMEOUT_SECONDS=60
OPENCLAW_AUTO_REPLY_ENABLED=True
OPENCLAW_DRAFT_ENABLED=True
OPENCLAW_SYSTEM_LABEL=OpenClaw

CHAT_WIDGET_ENABLED=True
CHAT_REALTIME_ENABLED=False
CHANNEL_LAYER_BACKEND=memory
REDIS_URL=redis://127.0.0.1:6379/1

SHIP_FROM_ADDRESS_LINE1=
SHIP_FROM_ADDRESS_LINE2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_POSTAL_CODE=
SHIP_FROM_COUNTRY=US
