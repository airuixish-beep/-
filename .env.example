DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
USE_X_FORWARDED_HOST=True
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=same-origin
SECURE_CONTENT_TYPE_NOSNIFF=True
SITE_URL=https://your-domain.com
WEB_BIND=127.0.0.1
WEB_PORT=8000
DB_ENGINE=mysql
DB_NAME=xuanor
DB_USER=xuanor
DB_PASSWORD=replace-with-db-password
DB_HOST=db
DB_PORT=3306
MYSQL_ROOT_PASSWORD=replace-with-root-password
CACHE_BACKEND=filebased
CACHE_LOCATION=/var/tmp/xuanor-cache
CACHE_KEY_PREFIX=xuanor
CACHE_TABLE=django_cache
DEFAULT_CURRENCY=USD
DEFAULT_SHIPPING_AMOUNT=15.00
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BASE_URL=https://api-m.paypal.com
EASYPOST_API_KEY=
OPENCLAW_ENABLED=False
OPENCLAW_COMMAND=/usr/local/bin/openclaw
OPENCLAW_AGENT_ID=
OPENCLAW_TIMEOUT_SECONDS=60
OPENCLAW_AUTO_REPLY_ENABLED=True
OPENCLAW_DRAFT_ENABLED=True
OPENCLAW_SYSTEM_LABEL=OpenClaw
CHAT_WIDGET_ENABLED=True
CHAT_REALTIME_ENABLED=True
CHANNEL_LAYER_BACKEND=redis
REDIS_URL=redis://redis:6379/1
SHIP_FROM_ADDRESS_LINE1=
SHIP_FROM_ADDRESS_LINE2=
SHIP_FROM_CITY=
SHIP_FROM_STATE=
SHIP_FROM_POSTAL_CODE=
SHIP_FROM_COUNTRY=US
