<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>homebrew.mxcl.xuanor-daphne</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/wangguoyue/Desktop/xuanor_site &amp;&amp; source .venv/bin/activate &amp;&amp; export $(grep -v '^#' .env.local | xargs) &amp;&amp; exec daphne -b 127.0.0.1 -p 8000 config.asgi:application</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/wangguoyue/Desktop/xuanor_site</string>

  <key>StandardOutPath</key>
  <string>/tmp/xuanor-daphne.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/xuanor-daphne.error.log</string>
</dict>
</plist>
